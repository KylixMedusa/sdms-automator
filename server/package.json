{
  "name": "sdms-automator-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch index.ts",
    "start": "NODE_ENV=production tsx index.ts",
    "db:push": "npx drizzle-kit push",
    "db:migrate": "npx drizzle-kit migrate",
    "db:generate": "npx drizzle-kit generate",
    "db:studio": "npx drizzle-kit studio",
    "docker:build": "cd .. && docker build -f server/Dockerfile -t sdms-automator-server .",
    "docker:run": "docker run --env-file .env -p 3000:3000 --init --ipc=host --shm-size=1g sdms-automator-server",
    "docker:dev": "docker run --rm --env-file .env -p 3001:3001 --init --ipc=host --shm-size=1g -v $(pwd):/app -v sdms-node-modules:/app/node_modules -e PORT=3001 -e NODE_ENV=development sdms-automator-server sh -c 'Xvfb :99 -screen 0 1920x1080x24 -nolisten tcp & sleep 2 && export DISPLAY=:99 && npx tsx watch index.ts'",
    "docker:dev:rebuild": "docker volume rm sdms-node-modules 2>/dev/null; npm run docker:build && npm run docker:dev"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "tsx": "^4.21.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "typescript": "^6.0.2"
  }
}
