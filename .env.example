# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# Auth
APP_PIN=1234
JWT_SECRET=change-this-to-a-random-64-char-string

# Server
PORT=3001

# Playwright
HEADLESS=true

# Job Processor
JOB_TIMEOUT_MS=120000
MAX_RETRIES=2
POLL_INTERVAL_MS=3000

# Deployment (set these when using split deploy: Vercel + Railway)
# CORS_ORIGIN=https://sdms-automator.vercel.app
# VITE_API_URL=https://sdms-automator-production.up.railway.app
